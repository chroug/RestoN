{% extends 'base.html.twig' %}

{% block title %}Mon Profil - RestoN{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <div class="card shadow border-0 rounded-3">

                    <div class="card-header bg-primary text-white text-center py-4 border-0 rounded-top-3">
                        <div class="bg-white text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 80px; height: 80px;">
                            <i class="bi bi-person-fill display-4"></i>
                        </div>
                        <h2 class="fw-bold mb-0">{{ app.user.prenom|capitalize }} {{ app.user.nom|upper }}</h2>
                        <span class="badge bg-light text-primary mt-2 rounded-pill">
                            {% if 'ROLE_GERANT' in app.user.roles %}
                                Gérant
                            {% else %}
                                Client Membre
                            {% endif %}
                        </span>
                    </div>

                    <div class="card-body p-4">
                        <h5 class="text-muted mb-4 border-bottom pb-2">Mes Informations</h5>

                        <div class="row g-3">
                            <div class="col-12">
                                <div class="d-flex align-items-center p-3 border rounded bg-light">
                                    <div class="bg-white p-2 rounded-circle shadow-sm me-3 text-primary">
                                        <i class="bi bi-envelope-fill fs-5"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block">Adresse Email</small>
                                        <strong>{{ app.user.email }}</strong>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="d-flex align-items-center p-3 border rounded bg-light">
                                    <div class="bg-white p-2 rounded-circle shadow-sm me-3 text-success">
                                        <i class="bi bi-telephone-fill fs-5"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block">Téléphone</small>
                                        <strong>{{ app.user.telephone ? app.user.telephone : 'Non renseigné' }}</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-5">
                            <div class="col-6">
                                <a href="{{ path('app_restaurants') }}" class="btn btn-outline-secondary w-100 py-2">
                                    <i class="bi bi-arrow-left"></i> Retour
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="{{ path('app_logout') }}" class="btn btn-danger w-100 py-2">
                                    Déconnexion <i class="bi bi-box-arrow-right"></i>
                                </a>
                            </div>
                        </div>

                        <div class="mt-3 text-center">
                            <a href="{{ path('app_mes_commandes') }}" class="btn btn-link text-decoration-none fw-bold">
                                Voir mon historique de commandes
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
