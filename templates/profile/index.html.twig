{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
    <div class="container" style="margin-top: 50px; max-width: 600px;">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0">👤 Mon Profil Client</h2>
            </div>
            <div class="card-body">
                <table class="table">
                    <tr>
                        <th>Email :</th>
                        <td>{{ user.email }}</td>
                    </tr>
                    <tr>
                        <th>Rôle :</th>
                        <td>
                            {% if 'ROLE_CLIENT' in user.roles %}
                                Client
                            {% else %}
                                Utilisateur
                            {% endif %}
                        </td>
                    </tr>

                </table>

                <div class="d-grid gap-2 mt-4">
                    <a href="{{ path('app_restaurants') }}" class="btn btn-outline-secondary">
                        Retour à l'accueil
                    </a>
                    <a href="{{ path('app_logout') }}" class="btn btn-danger">
                        Se déconnecter
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
