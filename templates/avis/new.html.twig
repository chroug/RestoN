{% extends 'base.html.twig' %}

{% block title %}Laisser un avis{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h3 class="h5 mb-0">⭐ Noter votre commande chez {{ restaurant.nom }}</h3>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">
                            Votre avis aide les autres utilisateurs et permet au restaurateur de s'améliorer.
                        </p>

                        {{ form_start(form) }}
                        {{ form_widget(form) }}
                        {{ form_end(form) }}
                    </div>
                </div>

                <div class="mt-3 text-center">
                    <a href="{{ path('app_mes_commandes') }}" class="text-decoration-none">
                        &larr; Retour à mes commandes
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
