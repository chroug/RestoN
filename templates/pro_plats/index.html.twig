{% extends 'base.html.twig' %}

{% block title %}Gérer ma Carte{% endblock %}

{% block body %}
    <div class="container mt-4">

        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
            <div>
                <h1 class="h2 mb-0">Ma Carte</h1>
                <p class="text-muted small mb-0">Gérez les plats de votre restaurant</p>
            </div>
            <div class="d-flex gap-2">

                {% if app.user.restaurant %}
                    <a href="{{ path('app_admin_restaurant_edit', {'id': app.user.restaurant.id}) }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Retour au Resto
                    </a>
                {% endif %}


                <a href="{{ path('app_pro_plats_new') }}" class="btn btn-success shadow-sm">
                    <i class="bi bi-plus-circle"></i> Nouveau Plat
                </a>
            </div>
        </div>


        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                        <tr>
                            <th style="width: 25%;">Nom du Plat</th>
                            <th style="width: 40%;">Description</th>
                            <th style="width: 15%;">Prix</th>
                            <th style="width: 20%;" class="text-end">Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for plat in plats %}
                            <tr>
                                <td>
                                    <div class="fw-bold">{{ plat.nom }}</div>
                                </td>
                                <td class="text-muted small">
                                    {{ plat.description|slice(0, 50) }}...
                                </td>
                                <td class="fw-bold text-primary">
                                    {{ plat.prix }} €
                                </td>
                                <td class="text-end">

                                    <a href="#" class="btn btn-sm btn-outline-primary me-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="#" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-basket display-4 d-block mb-3"></i>
                                    Aucun plat dans votre carte pour le moment.
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
