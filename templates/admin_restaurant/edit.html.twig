{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord - {{ restaurant.nom }}{% endblock %}

{% block body %}
    <div class="container mt-4 pb-5">

        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
            <div>
                <h1 class="h2 mb-0">Tableau de Bord</h1>
                <p class="text-muted small mb-0">{{ restaurant.nom }}</p>
            </div>

            <div class="d-flex gap-2">
                <a href="{{ path('app_pro_plats_index') }}" class="btn btn-warning text-dark fw-bold shadow-sm">
                    <i class="bi bi-egg-fried"></i> Gérer la Carte
                </a>
            </div>
        </div>



        <div class="row g-3 mb-5">

            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-primary text-white h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-white-50 text-uppercase mb-2">Chiffre d'Affaires (Total)</h6>
                                <h2 class="display-6 fw-bold mb-0">{{ chiffreAffaires|number_format(2, ',', ' ') }} €</h2>
                            </div>
                            <i class="bi bi-currency-euro fs-1 opacity-25"></i>
                        </div>
                    </div>
                </div>
            </div>


            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-success text-white h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-white-50 text-uppercase mb-2">Commandes du jour</h6>
                                <h2 class="display-6 fw-bold mb-0">{{ nbCommandesJour }}</h2>
                            </div>
                            <i class="bi bi-receipt fs-1 opacity-25"></i>
                        </div>
                    </div>
                </div>
            </div>


            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-info text-white h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-white-50 text-uppercase mb-2">Serveurs actifs</h6>
                                <h2 class="display-6 fw-bold mb-0">{{ serveurs|length }}</h2>
                            </div>
                            <i class="bi bi-people-fill fs-1 opacity-25"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">

            <div class="col-lg-12 mb-5">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0"><i class="bi bi-person-badge"></i> Mon Équipe (Serveurs)</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                <tr>
                                    <th>Nom / Prénom</th>
                                    <th>Email</th>
                                    <th>Téléphone</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for serveur in serveurs %}
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="bg-light rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px;">
                                                    <i class="bi bi-person text-secondary"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-bold">{{ serveur.nom }} {{ serveur.prenom }}</div>
                                                    <small class="text-muted">Serveur</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>{{ serveur.email }}</td>
                                        <td>
                                            {% if serveur.telephone %}
                                                {{ serveur.telephone }}
                                            {% else %}
                                                <span class="text-muted fst-italic">Non renseigné</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end">

                                            <a href="#" class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-envelope"></i> Contacter
                                            </a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">
                                            Aucun serveur n'est associé à ce restaurant pour le moment.
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <hr class="my-5">

        <h3 class="mb-4">Modifier les informations & Horaires</h3>
        {{ form_start(form) }}

        <div class="row">
            <div class="col-md-5">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-dark text-white">
                        <h4 class="mb-0 fs-5"><i class="bi bi-shop"></i> Informations Générales</h4>
                    </div>
                    <div class="card-body">
                        {{ form_row(form.nom) }}
                        {{ form_row(form.adresse) }}
                        <div class="row">
                            <div class="col-6">{{ form_row(form.ville) }}</div>
                            <div class="col-6">{{ form_row(form.codePostal) }}</div>
                        </div>
                        {{ form_row(form.telephone) }}
                        <hr>
                        {{ form_row(form.nombrePlaces) }}
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-secondary text-white">
                        <h4 class="mb-0 fs-5"><i class="bi bi-clock"></i> Horaires d'ouverture</h4>
                    </div>
                    <div class="card-body p-0">

                        <div class="table-responsive">
                            <table class="table table-hover table-sm align-middle mb-0">
                                <thead class="table-light">
                                <tr>
                                    <th style="width: 15%">Jour</th>
                                    <th style="width: 35%">Midi</th>
                                    <th style="width: 35%">Soir</th>
                                    <th style="width: 15%" class="text-center">Fermé</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for horaireField in form.horaires %}
                                    <tr>
                                        <td class="fw-bold text-primary ps-3">
                                            {{ form_widget(horaireField.jour) }}
                                        </td>
                                        <td class="py-2">
                                            <div class="d-flex align-items-center gap-1">
                                                {{ form_widget(horaireField.ouvertureMidi, {'attr': {'class': 'form-control-sm text-center', 'style': 'max-width: 75px;'}}) }}
                                                <span class="text-muted">-</span>
                                                {{ form_widget(horaireField.fermetureMidi, {'attr': {'class': 'form-control-sm text-center', 'style': 'max-width: 75px;'}}) }}
                                            </div>
                                        </td>
                                        <td class="py-2">
                                            <div class="d-flex align-items-center gap-1">
                                                {{ form_widget(horaireField.ouvertureSoir, {'attr': {'class': 'form-control-sm text-center', 'style': 'max-width: 75px;'}}) }}
                                                <span class="text-muted">-</span>
                                                {{ form_widget(horaireField.fermetureSoir, {'attr': {'class': 'form-control-sm text-center', 'style': 'max-width: 75px;'}}) }}
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <div class="form-check form-switch d-flex justify-content-center">
                                                {{ form_widget(horaireField.ferme, {'attr': {'class': 'form-check-input'}}) }}
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="fixed-bottom bg-white border-top shadow p-3 d-flex justify-content-end align-items-center" style="z-index: 1050;">
            <div class="container d-flex justify-content-end gap-3">
                <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">Annuler</a>
                <button type="submit" class="btn btn-success fw-bold px-4 shadow-sm">
                    <i class="bi bi-check-lg"></i> Enregistrer les modifications
                </button>
            </div>
        </div>

        {{ form_end(form) }}
    </div>
{% endblock %}
