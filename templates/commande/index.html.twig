{% extends 'base.html.twig' %}

{% block title %}Mes Commandes{% endblock %}

{% block body %}
    <div class="container" style="margin-top: 50px;">
        <h1>Historique de mes commandes</h1>

        {% if commandes is empty %}
            <div class="alert alert-info">
                Vous n'avez pas encore passé de commande. <a href="{{ path('app_plats') }}">Allez manger !</a>
            </div>
        {% else %}
            <table class="table table-striped" style="margin-top: 20px;">
                <thead>
                <tr>
                    <th>Date</th>
                    <th>Statut</th>
                    <th>Type</th>
                    <th>Restaurant</th>
                    <th>Total</th>
                    <th>Détails</th>
                </tr>
                </thead>
                <tbody>
                {% for commande in commandes %}
                    <tr>
                        <td>{{ commande.date|date('d/m/Y H:i') }}</td>

                        <td>
                            {% if commande.statut == 1 %}
                                <span class="badge bg-warning text-dark">En attente de préparation</span>
                            {% elseif commande.statut == 2 %}
                                <span class="badge bg-primary">Prête</span>
                            {% else %}
                                <span class="badge bg-success">Terminée</span>
                            {% endif %}
                        </td>

                        <td>
                            {% if commande.AEmporter %}
                                À emporter
                            {% else %}
                                Sur place
                            {% endif %}
                        </td>

                        <td>
                            {{ commande.restaurant ? commande.restaurant.nom : 'Inconnu' }}
                        </td>
                        <td>
                            {% if commande.total %}
                                <strong>{{ commande.total }} €</strong>
                            {% else %}
                                -
                            {% endif %}
                        </td>
                        <td>
                            <ul>
                                {% for plat in commande.plats %}
                                    <li>{{ plat.nom }}</li>
                                {% endfor %}
                            </ul>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}

        <a href="{{ path('app_home') }}" class="btn btn-secondary">Retour à l'accueil</a>
    </div>
{% endblock %}
