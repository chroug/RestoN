{% extends 'base.html.twig' %}

{% block title %}Mes Commandes{% endblock %}

{% block body %}
    <div class="container" style="margin-top: 50px;">
        <h1>Historique de mes commandes</h1>

        {% if commandes is empty %}
            <div class="alert alert-info">
                Vous n'avez pas encore passé de commande. <a href="{{ path('app_plats') }}">Allez manger !</a>
            </div>
        {% else %}
            <table class="table table-striped" style="margin-top: 20px;">
                <thead>
                <tr>
                    <th>Date</th>
                    <th>Statut</th>
                    <th>Type</th>
                    <th>Restaurant</th>
                    <th>Total</th>
                    <th>Détails</th>
                </tr>
                </thead>
                <tbody>
                {% for commande in commandes %}
                    <tr>
                        <td>{{ commande.date|date('d/m/Y H:i') }}</td>

                        <td>
                            {% if commande.statut == 'EN_ATTENTE' %}
                                <span style="color: orange;">En attente</span>
                            {% elseif commande.statut == 'PAYEE' %}
                                <span style="color: green;">Payée</span>
                            {% else %}
                                {{ commande.statut }}
                            {% endif %}
                        </td>

                        <td>
                            {% if commande.AEmporter %}
                                À emporter
                            {% else %}
                                Sur place
                            {% endif %}
                        </td>

                        <td>
                            {{ commande.restaurant.nom ?? 'Inconnu' }}
                        </td>

                        <td>
                            <ul>
                                {% for ligne in commande.ligneCommandes %}
                                    <li>{{ ligne.quantite }}x {{ ligne.plat.nom }}</li>
                                {% endfor %}
                            </ul>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}

        <a href="{{ path('app_plats') }}" class="btn btn-secondary">Retour à l'accueil</a>
    </div>
{% endblock %}
