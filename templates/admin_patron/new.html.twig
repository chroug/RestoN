{% extends 'base.html.twig' %}

{% block title %}Nouveau Patron{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow border-0">
                    <div class="card-header bg-success text-white">
                        <h3 class="mb-0">Créer un Patron</h3>
                    </div>
                    <div class="card-body">
                        {{ form_start(form) }}
                        <div class="row">
                            <div class="col-md-6">{{ form_row(form.nom) }}</div>
                            <div class="col-md-6">{{ form_row(form.prenom) }}</div>
                        </div>
                        {{ form_row(form.email) }}
                        {{ form_row(form.plainPassword) }}
                        {{ form_row(form.restaurant) }}

                        <div class="d-flex justify-content-between mt-4">
                            <a href="{{ path('app_admin_patron_index') }}" class="btn btn-secondary">Retour</a>
                            <button class="btn btn-success">Enregistrer</button>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
