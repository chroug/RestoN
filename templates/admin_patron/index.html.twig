{% extends 'base.html.twig' %}

{% block title %}Gérer les Patrons - Admin{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row">
            <div class="col-12">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold mb-0" style="font-family: 'Playfair Display', serif; color: var(--dark);">
                        <i class="fas fa-user-tie me-2 text-primary"></i> Gérer les Patrons
                    </h2>

                    <a href="{{ path('app_admin_patron_new') }}" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
                        <i class="fas fa-plus-circle me-2"></i>Nouveau Patron
                    </a>
                </div>

                <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light border-bottom">
                                <tr>
                                    <th class="py-3 ps-4 text-uppercase small fw-bold text-muted" style="width: 80px;">ID</th>
                                    <th class="py-3 text-uppercase small fw-bold text-muted">Identité</th>
                                    <th class="py-3 text-uppercase small fw-bold text-muted">Email</th>
                                    <th class="py-3 text-uppercase small fw-bold text-muted">Restaurant</th>
                                    <th class="py-3 text-end pe-4 text-uppercase small fw-bold text-muted">Actions</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for patron in patrons %}
                                    <tr>
                                        <td class="ps-4 text-muted fw-bold">#{{ patron.id }}</td>

                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center me-3"
                                                     style="width: 40px; height: 40px; font-weight: bold; font-size: 0.9rem;">
                                                    {{ patron.prenom|first|upper }}{{ patron.nom|first|upper }}
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-dark">{{ patron.prenom }} {{ patron.nom|upper }}</div>
                                                    <div class="small text-muted">Compte actif</div>
                                                </div>
                                            </div>
                                        </td>

                                        <td class="text-muted">{{ patron.email }}</td>

                                        <td>
                                            {% if patron.restaurant %}
                                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 border border-primary border-opacity-10">
                                                    <i class="fas fa-utensils me-1"></i> {{ patron.restaurant.nom }}
                                                </span>
                                            {% else %}
                                                <span class="badge bg-light text-muted border rounded-pill px-3 py-2">
                                                    Aucun restaurant
                                                </span>
                                            {% endif %}
                                        </td>

                                        <td class="text-end pe-4">
                                            <a href="{{ path('app_admin_patron_edit', {'id': patron.id}) }}" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-bold">
                                                <i class="fas fa-pen me-1"></i> Modifier
                                            </a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <div class="text-muted opacity-50 mb-3">
                                                <i class="fas fa-users-slash fa-4x"></i>
                                            </div>
                                            <h5 class="fw-bold text-muted" style="font-family: 'Playfair Display', serif;">Aucun patron trouvé</h5>
                                            <p class="text-muted small">La liste est vide pour le moment.</p>
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
