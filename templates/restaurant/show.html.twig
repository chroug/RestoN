{% extends 'base.html.twig' %}

{% block title %}Carte - {{ restaurant.nom }}{% endblock %}

{% block body %}
    <div class="container-fluid px-4" style="margin-top: 30px;">

        <div class="row">
            <div class="col-md-2 d-none d-md-block">
                <div class="sticky-top" style="top: 20px;">
                    <div class="card shadow-sm border-primary">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="bi bi-basket"></i> Mon Panier</h5>
                        </div>

                        <div class="card-body">
                            {{ render(controller('App\\Controller\\CartController::summary')) }}
                        </div>

                        <div class="card-footer p-2">
                            <a href="{{ path('cart_index') }}" class="btn btn-success w-100">
                                PAYER
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded shadow-sm">
                    <h1 class="h2 m-0">Carte : {{ restaurant.nom }}</h1>
                    <a href="{{ path('app_restaurants') }}" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-arrow-left"></i> Changer
                    </a>
                </div>

                {% set entrees = plats|filter(p => p.category.name == 'Entrée') %}
                {% if entrees|length > 0 %}
                    <h3 class="text-success border-bottom pb-2 mb-3 mt-2">Entrées</h3>
                    <div class="row mb-4">
                        {% for plat in entrees %}
                            <div class="col-md-6 mb-4">
                                <div class="card h-100 shadow-sm">
                                    <div class="card-body d-flex flex-column">
                                        <div class="d-flex justify-content-between">
                                            <a href="{{ path('app_plat_show', {'id': plat.id}) }}" class="text-decoration-none text-dark">
                                                <h5 class="card-title fw-bold">{{ plat.nom }}</h5>
                                            </a>
                                            <span class="text-primary fw-bold">{{ plat.prix }}&nbsp;€</span>
                                        </div>
                                        <p class="card-text text-muted small flex-grow-1">{{ plat.description|default('Délicieux plat fait maison.') }}</p>

                                        {% set stockTotal = 0 %}
                                        {% for stock in plat.platsStocks %}
                                            {% set stockTotal = stockTotal + stock.quantite %}
                                        {% endfor %}

                                        <div class="mt-3 d-flex justify-content-between align-items-center">
                                            {% if stockTotal > 0 %}
                                                <span class="badge bg-success bg-opacity-10 text-success border border-success">En stock</span>
                                                <a href="{{ path('cart_add', {'id': plat.id}) }}" class="btn btn-sm btn-success rounded-pill px-3">
                                                    Ajouter <i class="bi bi-plus-lg"></i>
                                                </a>
                                            {% else %}
                                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger">Rupture</span>
                                                <button class="btn btn-sm btn-secondary rounded-pill px-3" disabled>Indisponible</button>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                {% set platsPrincipaux = plats|filter(p => p.category.name == 'Plat') %}
                {% if platsPrincipaux|length > 0 %}
                    <h3 class="text-primary border-bottom pb-2 mb-3 mt-4">Plats</h3>
                    <div class="row mb-4">
                        {% for plat in platsPrincipaux %}
                            <div class="col-md-6 mb-4">
                                <div class="card h-100 shadow-sm">
                                    <div class="card-body d-flex flex-column">
                                        <div class="d-flex justify-content-between">
                                            <a href="{{ path('app_plat_show', {'id': plat.id}) }}" class="text-decoration-none text-dark">
                                                <h5 class="card-title fw-bold">{{ plat.nom }}</h5>
                                            </a>
                                            <span class="text-primary fw-bold">{{ plat.prix }}&nbsp;€</span>
                                        </div>
                                        <p class="card-text text-muted small flex-grow-1">{{ plat.description|default('Délicieux plat fait maison.') }}</p>

                                        {% set stockTotal = 0 %}
                                        {% for stock in plat.platsStocks %}
                                            {% set stockTotal = stockTotal + stock.quantite %}
                                        {% endfor %}

                                        <div class="mt-3 d-flex justify-content-between align-items-center">
                                            {% if stockTotal > 0 %}
                                                <span class="badge bg-success bg-opacity-10 text-success border border-success">En stock</span>
                                                <a href="{{ path('cart_add', {'id': plat.id}) }}" class="btn btn-sm btn-success rounded-pill px-3">
                                                    Ajouter <i class="bi bi-plus-lg"></i>
                                                </a>
                                            {% else %}
                                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger">Rupture</span>
                                                <button class="btn btn-sm btn-secondary rounded-pill px-3" disabled>Indisponible</button>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                {% set desserts = plats|filter(p => p.category.name == 'Dessert') %}
                {% if desserts|length > 0 %}
                    <h3 class="text-warning border-bottom pb-2 mb-3 mt-4">Desserts</h3>
                    <div class="row mb-4">
                        {% for plat in desserts %}
                            <div class="col-md-6 mb-4">
                                <div class="card h-100 shadow-sm">
                                    <div class="card-body d-flex flex-column">
                                        <div class="d-flex justify-content-between">
                                            <a href="{{ path('app_plat_show', {'id': plat.id}) }}" class="text-decoration-none text-dark">
                                                <h5 class="card-title fw-bold">{{ plat.nom }}</h5>
                                            </a>
                                            <span class="text-primary fw-bold">{{ plat.prix }}&nbsp;€</span>
                                        </div>
                                        <p class="card-text text-muted small flex-grow-1">{{ plat.description|default('Délicieux plat fait maison.') }}</p>

                                        {% set stockTotal = 0 %}
                                        {% for stock in plat.platsStocks %}
                                            {% set stockTotal = stockTotal + stock.quantite %}
                                        {% endfor %}

                                        <div class="mt-3 d-flex justify-content-between align-items-center">
                                            {% if stockTotal > 0 %}
                                                <span class="badge bg-success bg-opacity-10 text-success border border-success">En stock</span>
                                                <a href="{{ path('cart_add', {'id': plat.id}) }}" class="btn btn-sm btn-success rounded-pill px-3">
                                                    Ajouter <i class="bi bi-plus-lg"></i>
                                                </a>
                                            {% else %}
                                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger">Rupture</span>
                                                <button class="btn btn-sm btn-secondary rounded-pill px-3" disabled>Indisponible</button>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                {% if plats is empty %}
                    <div class="alert alert-info">Ce restaurant n'a pas encore ajouté de plats.</div>
                {% endif %}

                <hr class="my-5">

                <div id="section-avis" class="bg-light p-4 rounded-3">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="mb-0">Avis des clients</h3>
                        {% if is_granted('ROLE_CLIENT') %}
                            <a href="{{ path('app_avis_new', {'id': restaurant.id}) }}" class="btn btn-warning text-dark fw-bold">
                                Écrire un avis
                            </a>
                        {% endif %}
                    </div>
                    {% if restaurant.avis is empty %}
                        <p class="text-muted fst-italic">Aucun avis pour le moment.</p>
                    {% else %}
                        {% for avis in restaurant.avis %}
                            <div class="card mb-3 border-0 shadow-sm">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <h6 class="fw-bold">{{ avis.client.prenom|default('Client') }}</h6>
                                        <small class="text-muted">{{ avis.date|date("d/m/Y") }}</small>
                                    </div>
                                    <div class="text-warning mb-2">
                                        {% for i in 1..5 %}
                                            {{ i <= avis.note ? '★' : '☆' }}
                                        {% endfor %}
                                    </div>
                                    <p class="mb-0">{{ avis.commentaire }}</p>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>

            </div>
            <div class="col-md-3">
                <div class="sticky-top" style="top: 20px;">
                    <div class="card shadow-sm mb-3 overflow-hidden">
                        <div class="ratio ratio-1x1 bg-light">
                            <iframe
                                src="https://maps.google.com/maps?q={{ restaurant.adresse|url_encode }}&t=&z=14&ie=UTF8&iwloc=&output=embed"
                                style="border:0;" loading="lazy">
                            </iframe>
                        </div>
                    </div>

                    <div class="card shadow-sm mb-3">
                        <div class="card-body text-center">
                            <h4 class="card-title">{{ restaurant.nom }}</h4>
                            <p class="small text-muted">{{ restaurant.adresse }}</p>
                            <div class="d-grid">
                                <button class="btn btn-outline-dark">Réserver une table</button>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm">
                        <div class="card-header bg-dark text-white">
                            <h6 class="mb-0"><i class="bi bi-clock"></i> Horaires</h6>
                        </div>
                        <ul class="list-group list-group-flush small">
                            {% for horaire in horaires|default([]) %}
                                <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap">
                                    <strong>{{ horaire.jour }}</strong>

                                    <div class="text-end ms-auto">
                                        {% if horaire.ferme %}
                                            <span class="badge bg-danger">Fermé</span>
                                        {% else %}
                                            {% if horaire.ouvertureMidi %}
                                                <div style="font-size: 0.9em;">
                                                    Midi: {{ horaire.ouvertureMidi|date('H:i') }}-{{ horaire.fermetureMidi|date('H:i') }}
                                                </div>
                                            {% endif %}

                                            {% if horaire.ouvertureSoir %}
                                                <div style="font-size: 0.9em;">
                                                    Soir: {{ horaire.ouvertureSoir|date('H:i') }}-{{ horaire.fermetureSoir|date('H:i') }}
                                                </div>
                                            {% endif %}
                                        {% endif %}
                                    </div>
                                </li>
                            {% else %}
                                <li class="list-group-item text-muted">Horaires non renseignés</li>
                            {% endfor %}
                        </ul>
                    </div>

                </div>
            </div>

        </div>
    </div>
{% endblock %}
