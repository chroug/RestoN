{% extends 'base.html.twig' %}

{% block title %}Carte - {{ restaurant.nom }}{% endblock %}

{% block body %}

    <style>
        .hover-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
    </style>

    <div class="container-fluid px-4" style="margin-top: 30px;">

        <div class="row">

            <div class="col-md-2 d-none d-md-block">
                <div class="sticky-column">
                    <div class="card shadow border-0 rounded-4 overflow-hidden">
                        <div class="card-header bg-dark text-white text-center fw-bold py-3">
                            <i class="fas fa-shopping-basket me-2"></i> Mon Panier
                        </div>

                        <div class="card-body p-2 bg-light">
                            {{ render(controller('App\\Controller\\CartController::summary')) }}
                        </div>

                        <div class="card-footer p-3 bg-white border-0">
                            <a href="{{ path('cart_index') }}" class="btn btn-success w-100 fw-bold shadow py-2 rounded-pill transform-scale">
                                PAYER <i class="fas fa-check-circle ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-7">

                <div class="d-flex justify-content-between align-items-center mb-5 bg-white p-4 rounded-4 shadow-sm">
                    <div>
                        <h1 class="h2 m-0 fw-bold" style="font-family: 'Playfair Display', serif;">{{ restaurant.nom }}</h1>
                        <p class="text-muted mb-0 mt-1"><i class="fas fa-map-pin text-danger me-2"></i> {{ restaurant.adresse }}</p>
                    </div>
                    <a href="{{ path('app_restaurants') }}" class="btn btn-light rounded-circle shadow-sm" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;" title="Retour">
                        <i class="fas fa-arrow-left"></i>
                    </a>
                </div>

                {% set entrees = plats|filter(p => p.category.name == 'Entrée') %}
                {% if entrees|length > 0 %}
                    <div class="d-flex align-items-center mb-4 mt-2">
                        <h3 class="text-success fw-bold m-0" style="font-family: 'Playfair Display', serif;">Entrées</h3>
                        <div class="flex-grow-1 ms-3 border-bottom border-success opacity-25"></div>
                    </div>

                    <div class="row mb-5">
                        {% for plat in entrees %}
                            <div class="col-md-6 mb-4" data-aos="fade-up">
                                <div class="card h-100 border-0 shadow-sm hover-card rounded-4">
                                    <div class="card-body d-flex flex-column p-4">
                                        <div class="d-flex justify-content-between mb-2">
                                            <h5 class="card-title fw-bold mb-0 text-dark">{{ plat.nom }}</h5>
                                            <span class="fw-bold text-success fs-5">{{ plat.prix }} €</span>
                                        </div>
                                        <p class="card-text text-muted small flex-grow-1">{{ plat.description|default('Une entrée savoureuse pour commencer.') }}</p>

                                        <div class="mt-3 d-flex justify-content-between align-items-center">
                                            {% set stockTotal = 0 %}
                                            {% for stock in plat.platsStocks %}
                                                {% set stockTotal = stockTotal + stock.quantite %}
                                            {% endfor %}

                                            {% if stockTotal > 0 %}
                                                <span class="badge bg-light text-success border border-success rounded-pill px-3">En stock</span>
                                                <a href="{{ path('cart_add', {'id': plat.id}) }}" class="btn btn-success rounded-pill px-4 fw-bold btn-sm shadow-sm text-white">
                                                    Ajouter <i class="fas fa-plus ms-1"></i>
                                                </a>
                                            {% else %}
                                                <span class="badge bg-light text-danger border border-danger rounded-pill px-3">Épuisé</span>
                                                <button class="btn btn-light rounded-pill px-3 text-muted btn-sm" disabled>Indisponible</button>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                {% set platsPrincipaux = plats|filter(p => p.category.name == 'Plat') %}
                {% if platsPrincipaux|length > 0 %}
                    <div class="d-flex align-items-center mb-4">
                        <h3 class="text-primary fw-bold m-0" style="font-family: 'Playfair Display', serif;">Plats Principaux</h3>
                        <div class="flex-grow-1 ms-3 border-bottom border-primary opacity-25"></div>
                    </div>

                    <div class="row mb-5">
                        {% for plat in platsPrincipaux %}
                            <div class="col-md-6 mb-4" data-aos="fade-up">
                                <div class="card h-100 border-0 shadow-sm hover-card rounded-4">
                                    <div class="card-body d-flex flex-column p-4">
                                        <div class="d-flex justify-content-between mb-2">
                                            <h5 class="card-title fw-bold mb-0 text-dark">{{ plat.nom }}</h5>
                                            <span class="fw-bold text-primary fs-5">{{ plat.prix }} €</span>
                                        </div>
                                        <p class="card-text text-muted small flex-grow-1">{{ plat.description|default('La spécialité de la maison.') }}</p>

                                        <div class="mt-3 d-flex justify-content-between align-items-center">
                                            {% set stockTotal = 0 %}
                                            {% for stock in plat.platsStocks %}
                                                {% set stockTotal = stockTotal + stock.quantite %}
                                            {% endfor %}

                                            {% if stockTotal > 0 %}
                                                <span class="badge bg-light text-dark border rounded-pill px-3">En stock</span>
                                                <a href="{{ path('cart_add', {'id': plat.id}) }}" class="btn btn-reston rounded-pill px-4 btn-sm shadow-sm">
                                                    Ajouter <i class="fas fa-plus ms-1"></i>
                                                </a>
                                            {% else %}
                                                <span class="badge bg-light text-danger border border-danger rounded-pill px-3">Épuisé</span>
                                                <button class="btn btn-light rounded-pill px-3 text-muted btn-sm" disabled>Indisponible</button>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                {% set desserts = plats|filter(p => p.category.name == 'Dessert') %}
                {% if desserts|length > 0 %}
                    <div class="d-flex align-items-center mb-4">
                        <h3 class="text-warning fw-bold m-0" style="font-family: 'Playfair Display', serif;">Desserts</h3>
                        <div class="flex-grow-1 ms-3 border-bottom border-warning opacity-25"></div>
                    </div>

                    <div class="row mb-5">
                        {% for plat in desserts %}
                            <div class="col-md-6 mb-4" data-aos="fade-up">
                                <div class="card h-100 border-0 shadow-sm hover-card rounded-4">
                                    <div class="card-body d-flex flex-column p-4">
                                        <div class="d-flex justify-content-between mb-2">
                                            <h5 class="card-title fw-bold mb-0 text-dark">{{ plat.nom }}</h5>
                                            <span class="fw-bold text-warning fs-5">{{ plat.prix }} €</span>
                                        </div>
                                        <p class="card-text text-muted small flex-grow-1">{{ plat.description|default('Une douceur pour finir.') }}</p>

                                        <div class="mt-3 d-flex justify-content-between align-items-center">
                                            {% set stockTotal = 0 %}
                                            {% for stock in plat.platsStocks %}
                                                {% set stockTotal = stockTotal + stock.quantite %}
                                            {% endfor %}

                                            {% if stockTotal > 0 %}
                                                <span class="badge bg-light text-warning border border-warning rounded-pill px-3 text-dark">En stock</span>
                                                <a href="{{ path('cart_add', {'id': plat.id}) }}" class="btn btn-warning text-white rounded-pill px-4 fw-bold btn-sm shadow-sm">
                                                    Ajouter <i class="fas fa-plus ms-1"></i>
                                                </a>
                                            {% else %}
                                                <span class="badge bg-light text-danger border border-danger rounded-pill px-3">Épuisé</span>
                                                <button class="btn btn-light rounded-pill px-3 text-muted btn-sm" disabled>Indisponible</button>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                {% if plats is empty %}
                    <div class="alert alert-light text-center py-5 shadow-sm rounded-4">
                        <i class="fas fa-utensils fa-3x mb-3 text-muted opacity-25"></i>
                        <h4>La carte est vide pour le moment</h4>
                        <p class="text-muted">Revenez plus tard pour découvrir nos plats !</p>
                    </div>
                {% endif %}

                <div id="section-avis" class="bg-white p-5 rounded-4 shadow-sm mb-5 pb-5">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="mb-0 fw-bold" style="font-family: 'Playfair Display', serif;">Avis des clients</h3>
                        {% if is_granted('ROLE_CLIENT') %}
                            <a href="{{ path('app_avis_new', {'id': restaurant.id}) }}" class="btn btn-outline-dark rounded-pill px-4 fw-bold">
                                <i class="fas fa-pen me-2"></i>Écrire un avis
                            </a>
                        {% endif %}
                    </div>

                    {% if restaurant.avis is empty %}
                        <div class="text-center py-5 bg-light rounded-3">
                            <i class="far fa-comment-dots fa-2x mb-3 text-muted"></i>
                            <p class="text-muted mb-0">Aucun avis pour l'instant. Soyez le premier !</p>
                        </div>
                    {% else %}
                        <div class="row">
                            {% for avis in restaurant.avis %}
                                <div class="col-12 mb-3">
                                    <div class="card border-0 bg-light rounded-3">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-white rounded-circle d-flex align-items-center justify-content-center shadow-sm me-3" style="width: 40px; height: 40px;">
                                                        <i class="fas fa-user text-muted"></i>
                                                    </div>
                                                    <div>
                                                        <h6 class="fw-bold mb-0">{{ avis.client.prenom|default('Client') }}</h6>
                                                        <div class="text-warning small">
                                                            {% for i in 1..5 %}
                                                                {% if i <= avis.note %}<i class="fas fa-star"></i>{% else %}<i class="far fa-star text-muted opacity-25"></i>{% endif %}
                                                            {% endfor %}
                                                        </div>
                                                    </div>
                                                </div>
                                                <small class="text-muted">{{ avis.date|date("d/m/Y") }}</small>
                                            </div>
                                            <p class="mb-0 text-secondary ps-5">{{ avis.commentaire }}</p>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                    <div class="py-4"></div>
                </div>

            </div>

            <div class="col-md-3">
                <div class="sticky-column">

                    <div class="card shadow-sm mb-4 overflow-hidden border-0 rounded-4">
                        <div class="ratio ratio-4x3">
                            <iframe
                                src="https://maps.google.com/maps?q={{ restaurant.adresse|url_encode }}&t=&z=14&ie=UTF8&iwloc=&output=embed"
                                style="border:0;"
                                allowfullscreen=""
                                loading="lazy">
                            </iframe>
                        </div>
                    </div>

                    <div class="card shadow-sm mb-4 border-0 rounded-4">
                        <div class="card-body text-center p-4">
                            <div class="mb-3">
                                <span class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                    <i class="fas fa-store fa-2x"></i>
                                </span>
                            </div>
                            <h4 class="card-title fw-bold">{{ restaurant.nom }}</h4>
                            <p class="small text-muted mb-4">{{ restaurant.adresse }}</p>

                            <div class="d-grid gap-2">
                                <button class="btn btn-dark rounded-pill py-2">
                                    <i class="fas fa-calendar-alt me-2"></i>Réserver une table
                                </button>

                                {% if is_granted('ROLE_GERANT') or (is_granted('ROLE_PATRON') and app.user.restaurant == restaurant) %}
                                    <a href="{{ path('app_admin_restaurant_edit', {'id': restaurant.id}) }}" class="btn btn-warning rounded-pill fw-bold text-dark">
                                        <i class="fas fa-cog me-2"></i>Gérer ce restaurant
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0 rounded-4">
                        <div class="card-header bg-white border-0 py-3">
                            <h6 class="mb-0 fw-bold"><i class="far fa-clock me-2 text-primary"></i> Horaires d'ouverture</h6>
                        </div>
                        <div class="card-body pt-0">
                            <ul class="list-unstyled mb-0 small">
                                {% for horaire in horaires|default([]) %}
                                    <li class="d-flex justify-content-between align-items-center py-2 border-bottom border-light">
                                        <strong class="text-uppercase text-muted" style="font-size: 0.85em;">{{ horaire.jour|slice(0,3) }}</strong>

                                        {% if horaire.ferme %}
                                            <span class="badge bg-light text-danger">Fermé</span>
                                        {% else %}
                                            <div class="text-end">
                                                {% if horaire.ouvertureMidi %}
                                                    <div>{{ horaire.ouvertureMidi|date('H:i') }} - {{ horaire.fermetureMidi|date('H:i') }}</div>
                                                {% endif %}
                                                {% if horaire.ouvertureSoir %}
                                                    <div>{{ horaire.ouvertureSoir|date('H:i') }} - {{ horaire.fermetureSoir|date('H:i') }}</div>
                                                {% endif %}
                                            </div>
                                        {% endif %}
                                    </li>
                                {% else %}
                                    <li class="text-muted text-center py-3">Horaires non renseignés</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
{% endblock %}
