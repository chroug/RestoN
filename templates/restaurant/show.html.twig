{% extends 'base.html.twig' %}

{% block title %}Carte - {{ restaurant.nom }}{% endblock %}

{% block body %}
    <div class="container" style="margin-top: 30px;">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Carte : {{ restaurant.nom }}</h1>
            <a href="{{ path('app_restaurants') }}" class="btn btn-outline-secondary"> Changer de restaurant</a>
        </div>

        <div class="row">
            {% for plat in plats %}
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        {# GESTION IMAGE (pour plus tard si pas la flemme) #}
                        {# {% if plat.image %}
                        <img src="{{ asset('uploads/images/' ~ plat.image) }}" class="card-img-top" alt="{{ plat.nom }}" style="height: 200px; object-fit: cover;">
                    {% endif %} #}

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">{{ plat.nom }}</h5>


                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <span class="h4 text-primary mb-0">{{ plat.prix }} €</span>

                                <a href="{{ path('cart_add', {'id': plat.id}) }}" class="btn btn-success">
                                    Ajouter
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-info">Ce restaurant n'a pas encore ajouté de plats.</div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
