{% extends 'base.html.twig' %}

{% block title %}Restaurants{% endblock %}

{% block body %}
    <div class="container" style="margin-top: 30px;">

        {% if is_granted('ROLE_CLIENT') %}
            <div class="p-4 mb-4 bg-light rounded-3 shadow-sm border">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <div>
                        <h2 class="text-primary fw-bold">Bonjour, {{ app.user.prenom }} ! 👋</h2>
                        <p class="text-muted mb-0">Une petite faim ?</p>
                    </div>
                    <div class="d-flex gap-2 mt-2 mt-md-0">
                        <a href="{{ path('app_profile') }}" class="btn btn-outline-dark btn-sm">
                            <i class="bi bi-person"></i> Profil
                        </a>
                        <a href="{{ path('app_mes_commandes') }}" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-receipt"></i> Commandes
                        </a>
                        <a href="{{ path('cart_index') }}" class="btn btn-success btn-sm">
                            <i class="bi bi-cart"></i> Panier
                        </a>
                    </div>
                </div>
            </div>
        {% endif %}

        <div class="row align-items-center mb-5">
            <div class="col-md-6">
                <h1 class="fw-bold mb-0">Nos Restaurants Partenaires</h1>
            </div>

            <div class="col-md-6 mt-3 mt-md-0">
                <form action="{{ path('app_restaurants') }}" method="GET" class="d-flex" role="search">
                    <div class="input-group">
                        <span class="input-group-text bg-white text-muted border-end-0">
                            <i class="bi bi-search"></i>
                        </span>
                        <input class="form-control border-start-0 ps-0"
                               type="search"
                               name="q"
                               placeholder="Rechercher un restaurant"
                               aria-label="Search"
                               value="{{ searchTerm|default('') }}">

                        <button class="btn btn-primary" type="submit">Rechercher</button>

                        {% if searchTerm is defined and searchTerm %}
                            <a href="{{ path('app_restaurants') }}" class="btn btn-outline-danger" title="Effacer la recherche">
                                <i class="bi bi-x-lg"></i>
                            </a>
                        {% endif %}
                    </div>
                </form>
            </div>
        </div>

        {% if restaurants is empty and searchTerm is defined and searchTerm %}
            <div class="alert alert-warning text-center mb-5">
                <i class="bi bi-exclamation-circle me-2"></i>
                Aucun restaurant ne correspond à votre recherche "<strong>{{ searchTerm }}</strong>".
                <br>
                <a href="{{ path('app_restaurants') }}" class="alert-link mt-2 d-inline-block">Voir tous les restaurants</a>
            </div>
        {% endif %}

        <div class="row">
            {% for restaurant in restaurants %}
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 overflow-hidden">

                        <div class="ratio ratio-21x9 bg-light">
                            <iframe
                                src="https://maps.google.com/maps?q={{ restaurant.adresse|url_encode }}&t=&z=14&ie=UTF8&iwloc=&output=embed"
                                style="border:0;"
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade">
                            </iframe>
                        </div>

                        <div class="card-body text-center d-flex flex-column">
                            <h3 class="card-title fw-bold mt-2">{{ restaurant.nom }}</h3>

                            <p class="text-muted small mb-3 flex-grow-1">
                                <i class="bi bi-geo-alt-fill text-danger"></i> {{ restaurant.adresse }}
                            </p>

                            <a href="{{ path('app_restaurant_show', {'id': restaurant.id}) }}" class="btn btn-primary w-100 fw-bold">
                                Voir la carte <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                {% if searchTerm is not defined or not searchTerm %}
                    <div class="col-12">
                        <div class="alert alert-info text-center">
                            Aucun restaurant n'est disponible pour le moment.
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    </div>
{% endblock %}
