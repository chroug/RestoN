{% extends 'base.html.twig' %}

{% block title %}Accueil - Restaurants{% endblock %}

{% block body %}
    <div class="container" style="margin-top: 30px;">

        {% if is_granted('ROLE_CLIENT') %}
            <div class="p-4 mb-4 bg-light rounded-3 shadow-sm border">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <div>
                        <h2 class="text-primary">Bonjour, {{ app.user.prenom }} ! </h2>
                        <p class="text-muted">Prêt à commander ?</p>
                    </div>

                    <div class="d-flex gap-2">
                        <a href="{{ path('app_profile') }}" class="btn btn-outline-dark">
                             Mon Profil
                        </a>
                        <a href="{{ path('app_mes_commandes') }}" class="btn btn-outline-primary">
                             Mes Commandes
                        </a>
                        <a href="{{ path('cart_index') }}" class="btn btn-success">
                             Mon Panier
                        </a>
                    </div>
                </div>
            </div>
        {% endif %}

        <h1 class="text-center mb-4"> Où souhaitez-vous manger ?</h1>

        <div class="row">
            {% for restaurant in restaurants %}
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm hover-effect">
                        <div class="card-body text-center">
                            <div style="font-size: 3rem; margin-bottom: 10px;"></div>
                            <h3 class="card-title">{{ restaurant.nom }}</h3>


                             <p class="text-muted">{{ restaurant.adresse }}</p>

                            <a href="{{ path('app_restaurant_show', {'id': restaurant.id}) }}" class="btn btn-primary mt-3 w-100">
                                Voir la carte
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="alert alert-warning text-center">
                    Aucun restaurant disponible pour le moment.
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
