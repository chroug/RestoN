{% extends 'base.html.twig' %}

{% block title %}Nos Restaurants{% endblock %}

{% block body %}
    <div class="container" style="margin-top: 50px;">
        <h1 class="text-center mb-5">Choisissez votre Restaurant</h1>

        <div class="row">
            {% for restaurant in restaurants %}
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        {# mettre image de resto ici #}
                        <div class="card-body text-center">
                            <h3 class="card-title">{{ restaurant.nom }}</h3>


                            <p class="text-muted">{{ restaurant.adresse }}</p>

                            <a href="{{ path('app_restaurant_show', {'id': restaurant.id}) }}" class="btn btn-primary mt-3">
                                Voir la carte
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="alert alert-warning">Aucun restaurant disponible pour le moment.</div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
