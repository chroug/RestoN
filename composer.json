{
    "name": "symfony/skeleton",
    "type": "project",
    "license": "proprietary",
    "description": "A minimal Symfony project recommended to create bare bones applications",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^3.1",
        "doctrine/doctrine-migrations-bundle": "^3.7",
        "doctrine/orm": "^3.5",
        "phpdocumentor/reflection-docblock": "^5.6",
        "phpstan/phpdoc-parser": "^2.3",
        "symfony/asset": "8.0.*",
        "symfony/asset-mapper": "8.0.*",
        "symfony/console": "8.0.*",
        "symfony/doctrine-messenger": "8.0.*",
        "symfony/dotenv": "8.0.*",
        "symfony/expression-language": "8.0.*",
        "symfony/flex": "^2",
        "symfony/form": "8.0.*",
        "symfony/framework-bundle": "8.0.*",
        "symfony/http-client": "8.0.*",
        "symfony/intl": "8.0.*",
        "symfony/mailer": "8.0.*",
        "symfony/mime": "8.0.*",
        "symfony/monolog-bundle": "^3.0|^4.0",
        "symfony/notifier": "8.0.*",
        "symfony/process": "8.0.*",
        "symfony/property-access": "8.0.*",
        "symfony/property-info": "8.0.*",
        "symfony/runtime": "8.0.*",
        "symfony/security-bundle": "8.0.*",
        "symfony/serializer": "8.0.*",
        "symfony/stimulus-bundle": "^2.31",
        "symfony/string": "8.0.*",
        "symfony/translation": "8.0.*",
        "symfony/twig-bundle": "8.0.*",
        "symfony/ux-turbo": "^2.31",
        "symfony/validator": "8.0.*",
        "symfony/web-link": "8.0.*",
        "symfony/yaml": "8.0.*",
        "symfonycasts/verify-email-bundle": "^1.18",
        "twig/extra-bundle": "^2.12|^3.0",
        "twig/twig": "^2.12|^3.0"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "scripts": {
        "start": "symfony serve",
        "test:phpcs": "php-cs-fixer fix --dry-run --diff --config .php-cs-fixer.dist.php",
        "fix:phpcs": "php-cs-fixer fix --config .php-cs-fixer.dist.php",
        "test:twigcs": "twigcs lint templates --severity error",
        "fix:twigcs": "twig-cs-fixer fix templates",
        "test:codeception": [
            "php vendor/bin/codecept clean",
            "bin/console doctrine:database:drop --force --quiet --env=test",
            "bin/console doctrine:database:create --quiet --env=test",
            "bin/console doctrine:schema:create --quiet --env=test",
            "php vendor/bin/codecept run"
        ],
        "db": ["php bin/console doctrine:database:drop --force --if-exists",
            " php bin/console doctrine:database:create",
            "php bin/console doctrine:migrations:migrate --no-interaction",
            "php bin/console doctrine:fixtures:load --no-interaction"],

        "test": ["@test:phpcs", "@test:twigcs", "@test:codeception"],
        "fix": ["@fix:phpcs", "@fix:twigcs"],

        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*"
        }
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.3",
        "phpunit/phpunit": "^12.4",
        "symfony/browser-kit": "8.0.*",
        "symfony/css-selector": "8.0.*",
        "symfony/debug-bundle": "8.0.*",
        "symfony/maker-bundle": "^1.65.1",
        "symfony/stopwatch": "8.0.*",
        "symfony/web-profiler-bundle": "8.0.*",
        "zenstruck/foundry": "^2.8"
    },
    "scripts-descriptions": {
        "start": "demarrage du serveur web",
        "test:phpcs": "démarrage de la verification du code par php cs fixer",
        "fix:phpcs": "démarrage de la correction du code par php cs fixer",
        "test:twigcs": "démarrage de la verification du code par twig cs fixer",
        "fix:twigcs": "démarrage de la correction du code par php cs fixer",
        "test": "demarrage des scripts de verification du code par php cs fixer et php twig fixer et codeception",
        "fix": "demarrage des scripts de correction du code par php cs fixer et php twig fixer",
    "test:codeception" : "demarrage des tests avec codeception : Nettoyage du répertoire « _output » et du code généré par Codeception, Destruction silencieuse forcée de la base de données, Création silencieuse de la base de données , Création silencieuse du schéma de la base de données , Exécution des tests Codeception   ",
    "db" : "Destruction forcée de la base de données , Création de la base de données, Application des migrations successives sans questions interactives, Génération des données factices sans questions interactives "
}


}
